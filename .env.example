# Variables de entorno de ejemplo.
# No colocar credenciales reales en este archivo.

ASPNETCORE_ENVIRONMENT=Development

API_PORT=5000
FRONTEND_PORT=5173

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CONNECTION=redis:6379

SQLSERVER_HOST=db
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=NumericalMethodsDb
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=Your_password123

DB_CONNECTION=Server=db;Database=NumericalMethodsDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True;